# PhishGuard AI – Backend Environment Variables
# Copy this file to .env and fill in your values.

# ── Server ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development         # development | production | test
HOST=0.0.0.0
PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for all during development)
ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://*

# ── API Keys (optional integrations) ────────────────────────────────────────
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key_here

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=../ml-model/models/phishguard_model.joblib
